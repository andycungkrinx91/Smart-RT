# =============================================================================
# Smart-RT Frontend Admin (Next.js)
# Salin file ini: cp .env.example .env
# Variabel di bawah sinkron dengan frontend-admin/src/lib/env.ts.
# =============================================================================

# URL internal backend FastAPI yang diakses dari Route Handler Next.js.
# Docker Compose: http://backend:8000
# Local host:     http://localhost:8000
API_BASE_URL=http://backend:8000

# Harus sama persis dengan API_KEY di backend/.env
# Server-side only (tidak di-prefix NEXT_PUBLIC_).
BACKEND_API_KEY=ganti_dengan_api_key_backend

# URL publik frontend admin untuk validasi origin (CSRF guard).
# Development: http://localhost:3000
# Production:  https://smart-rt.id
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Lebar gambar saat disisipkan ke canvas editor blog (persen, 10-100)
NEXT_PUBLIC_BLOG_IMAGE_WIDTH_PERCENT=70
