# =============================================================================
# Smart-RT Backend (FastAPI)
# Salin file ini: cp .env.example .env
# Variabel di bawah sinkron dengan backend/app/core/config.py + app/main.py.
# =============================================================================

# ---------------------------------------------------------------------------
# App & Domain
# ---------------------------------------------------------------------------
APP_NAME=Smart-RT
ENV=dev
BASE_URL=http://localhost:8000

# Domain utama SaaS untuk allowlist CORS (mendukung subdomain).
SAAS_DOMAIN=smart-rt.id

# Opsional: override regex CORS secara penuh.
# Contoh: ^https?://([a-z0-9-]+\.)?smart-rt\.id(:\d{1,5})?$
# SAAS_ORIGIN_REGEX=

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
SECRET_KEY=ganti_dengan_secret_panjang_random_minimal_64_karakter
API_KEY=ganti_dengan_api_key_acak_yang_kuat
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=3600

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Default stack project (Docker Compose): MySQL 8
DATABASE_URL=mysql+asyncmy://smart_rt:smart_rt@db:3306/smart_rt

# Alternatif PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://smart_rt:smart_rt@db:5432/smart_rt

# Alternatif MariaDB:
# DATABASE_URL=mariadb+asyncmy://smart_rt:smart_rt@db:3306/smart_rt

# SSL database (PostgreSQL/MySQL/MariaDB)
DB_SSL=false

# Legacy compatibility (opsional, tetap didukung di codebase).
# POSTGRES_SSL=false

# Untuk MySQL 8 jika SSL dimatikan.
MYSQL_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# ---------------------------------------------------------------------------
# Redis Session (JTI)
# ---------------------------------------------------------------------------
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# Bootstrap Admin
# ---------------------------------------------------------------------------
DEFAULT_ADMIN_EMAIL=admin@smart-rt.id
DEFAULT_ADMIN_PASSWORD=ganti_password_admin_sebelum_production
DEFAULT_ADMIN_NAME=Administrator

# ---------------------------------------------------------------------------
# Seed Data
# ---------------------------------------------------------------------------
SEED_DATA=true
SEED_SAMPLE_BLOG=true

# ---------------------------------------------------------------------------
# Secure Image Upload
# ---------------------------------------------------------------------------
IMAGE_STORAGE_ROOT=/app/storage
IMAGE_PUBLIC_BASE=/storage
IMAGE_MAX_BYTES=10485760
IMAGE_MAX_PIXELS=25000000
IMAGE_WEBP_QUALITY=85
IMAGE_RESIZE_RATIO=0.7
